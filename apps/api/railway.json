{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder":      "NIXPACKS",
    "buildCommand": "cd ../.. && pnpm build --filter @repo/api"
  },
  "deploy": {
    "startCommand": "node apps/api/dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
